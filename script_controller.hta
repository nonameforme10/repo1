<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel</title>
    <HTA:APPLICATION
        APPLICATIONNAME="ServerController"
        SCROLL="no"
        SINGLEINSTANCE="yes"
        WINDOWSTATE="normal"
        BORDER="dialog"
        MAXIMIZEBUTTON="no"
        MINIMIZEBUTTON="yes"
        SYSMENU="yes"
        CAPTION="yes"
    >
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap');
        
        * { box-sizing: border-box; }
        
        body {
            background-color: #1a1410;
            background-image: 
                url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
            background-blend-mode: soft-light;
            color: #e8dcc8;
            font-family: 'Source Sans 3', 'Segoe UI', Tahoma, sans-serif;
            text-align: center;
            padding: 0; margin: 0; overflow: hidden; min-height: 100vh; position: relative;
        }
        
        body::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: 
                radial-gradient(ellipse at 20% 20%, rgba(139, 90, 43, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(45, 30, 15, 0.3) 0%, transparent 50%),
                linear-gradient(180deg, rgba(26, 20, 16, 0.9) 0%, rgba(35, 25, 18, 0.95) 100%);
            pointer-events: none; z-index: 0;
        }
        
        .panel { display: none; position: relative; z-index: 1; padding: 30px; height: 100vh; }
        #login-panel { display: block; margin-top: 0; display: flex; flex-direction: column; justify-content: center; align-items: center; }
        
        .brand-mark { margin-bottom: 40px; }
        .brand-mark svg { width: 60px; height: 60px; opacity: 0.9; }
        .brand-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 28px; font-weight: 600; letter-spacing: 3px; color: #d4c4a8; margin: 0 0 8px 0; text-transform: uppercase; }
        .brand-subtitle { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #8b7355; margin: 0; font-weight: 300; }
        .divider { width: 60px; height: 1px; background: linear-gradient(90deg, transparent, #6b5a42, transparent); margin: 30px auto; }
        .section-label { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 14px; letter-spacing: 2px; color: #a89070; text-transform: uppercase; margin-bottom: 20px; }
        
        input[type="password"] { padding: 14px 20px; border-radius: 2px; border: 1px solid #3d3025; background: rgba(20, 15, 10, 0.8); color: #e8dcc8; margin-bottom: 16px; width: 240px; font-family: 'Source Sans 3', sans-serif; font-size: 14px; letter-spacing: 1px; transition: all 0.3s ease; }
        input[type="password"]:focus { outline: none; border-color: #6b5a42; background: rgba(25, 18, 12, 0.9); }
        input[type="password"]::placeholder { color: #5a4a38; font-style: italic; }
        
        .btn { background: transparent; color: #c9b896; border: 1px solid #4a3d2e; padding: 12px 32px; font-size: 12px; border-radius: 2px; cursor: pointer; margin: 6px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; font-family: 'Source Sans 3', sans-serif; transition: all 0.3s ease; position: relative; overflow: hidden; }
        .btn::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(201, 184, 150, 0.1), transparent); transition: left 0.5s ease; }
        .btn:hover::before { left: 100%; }
        .btn:hover { background: rgba(74, 61, 46, 0.4); border-color: #6b5a42; color: #e8dcc8; }
        .btn:active { transform: scale(0.98); }
        .btn-primary { background: rgba(107, 90, 66, 0.3); border-color: #6b5a42; }
        .btn-stop { border-color: #8b4a3a; color: #d4a090; }
        .btn-stop:hover { background: rgba(139, 74, 58, 0.3); border-color: #a65d4a; }
        .btn-refresh { font-size: 10px; padding: 8px 16px; letter-spacing: 1px; }
        
        .status { margin-top: 20px; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 13px; color: #7a6a55; letter-spacing: 1px; font-style: italic; }
        .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #4a3d2e; transition: all 0.3s ease; display: inline-block; margin-right: 8px; }
        .status-dot.online { background: #7a9a6a; box-shadow: 0 0 8px rgba(122, 154, 106, 0.5); }
        .status-dot.offline { background: #9a6a5a; }
        .error-text { color: #c49080; font-style: italic; }
        .success-text { color: #90c480; }
        
        .log-box { padding: 16px; background: rgba(12, 9, 6, 0.7); border: 1px solid #2a231a; border-radius: 2px; height: 160px; overflow-y: auto; text-align: left; font-family: 'Courier New', monospace; font-size: 11px; color: #8b9a7a; line-height: 1.8; margin-top: 24px; }
        .log-entry { border-bottom: 1px solid rgba(74, 61, 46, 0.3); padding: 6px 0; opacity: 0; animation: fadeIn 0.3s ease forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        .log-time { color: #6b5a42; margin-right: 8px; }
        
        .corner-accent { position: absolute; width: 40px; height: 40px; border: 1px solid rgba(107, 90, 66, 0.3); pointer-events: none; }
        .corner-accent.top-left { top: 20px; left: 20px; border-right: none; border-bottom: none; }
        .corner-accent.top-right { top: 20px; right: 20px; border-left: none; border-bottom: none; }
        .corner-accent.bottom-left { bottom: 20px; left: 20px; border-right: none; border-top: none; }
        .corner-accent.bottom-right { bottom: 20px; right: 20px; border-left: none; border-top: none; }
    </style>
</head>
<body>

    <div class="corner-accent top-left"></div>
    <div class="corner-accent top-right"></div>
    <div class="corner-accent bottom-left"></div>
    <div class="corner-accent bottom-right"></div>

    <div id="login-panel" class="panel">
        <div class="brand-mark">
            <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="30" cy="30" r="28" stroke="#6b5a42" stroke-width="1" fill="none"/>
                <path d="M30 10 C35 15, 40 20, 38 30 C36 40, 32 45, 30 50 C28 45, 24 40, 22 30 C20 20, 25 15, 30 10Z" 
                      fill="none" stroke="#8b7355" stroke-width="1"/>
                <ellipse cx="30" cy="30" rx="8" ry="12" fill="none" stroke="#a89070" stroke-width="0.5"/>
                <line x1="18" y1="25" x2="42" y2="25" stroke="#4a3d2e" stroke-width="0.5"/>
                <line x1="18" y1="35" x2="42" y2="35" stroke="#4a3d2e" stroke-width="0.5"/>
            </svg>
        </div>
        <p class="brand-subtitle">Server controller</p>        
        <div class="divider"></div>
        <p class="section-label">Administrator Access</p>
        <input type="password" id="passInput" placeholder="Enter passphrase...">
        <button class="btn btn-primary" onclick="checkAuth()">Authenticate</button>
        <div class="status" id="loginStatus"></div>
    </div>

    <div id="admin-panel" class="panel">
        <div style="text-align: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid rgba(74, 61, 46, 0.3);">
            <h2 class="brand-title">Server Control Panel</h2>
            <p class="brand-subtitle" style="font-size: 10px; margin-top: 6px;">Management Console</p>
        </div>
        
        <div style="display: flex; justify-content: center; gap: 16px; margin-bottom: 10px;">
            <button class="btn btn-primary" onclick="startServer()">Initialize Tunnel</button>
            <button class="btn btn-stop" onclick="stopServer()">Terminate Processes</button>
        </div>
        
        <div class="status">
            <span class="status-indicator">
                <span class="status-dot offline" id="statusDot"></span>
                <span id="statusBox">System Offline</span>
            </span>
        </div>

        <div class="log-box" id="logBox">
            <span style="color: #5a4a38; font-style: italic;">Awaiting tunnel initialization...</span>
        </div>
    </div>

    <script type="text/javascript">
        window.resizeTo(520, 620);
        var shell = new ActiveXObject("WScript.Shell");
        var initialLogsHtml = ""; // Persists our links

        var ADMIN_SALT = "72e791400790833b914e7dca09c681b7"; 
        var ADMIN_HASH = "7b37134b0cbbdb5be470801c33f97a2c303d8d4a9dec587416c454bf3a899c4d"; 

        function generateHash(ascii) {
            var mathPow = Math.pow, maxWord = mathPow(2, 32), i, j, result = '', words = [];
            var asciiBitLength = ascii.length * 8, hash = [], k = [], primeCounter = 0, isComposite = {};
            for (var candidate = 2; primeCounter < 64; candidate++) {
                if (!isComposite[candidate]) {
                    for (i = 0; i < 313; i += candidate) isComposite[i] = candidate;
                    hash[primeCounter] = (mathPow(candidate, .5) * maxWord) | 0;
                    k[primeCounter++] = (mathPow(candidate, 1 / 3) * maxWord) | 0;
                }
            }
            ascii += '\x80';
            while (ascii.length % 64 - 56) ascii += '\x00';
            for (i = 0; i < ascii.length; i++) {
                j = ascii.charCodeAt(i);
                words[i >> 2] |= j << ((3 - i % 4) * 8);
            }
            words[words.length] = ((asciiBitLength / maxWord) | 0);
            words[words.length] = (asciiBitLength);
            for (j = 0; j < words.length;) {
                var w = words.slice(j, j += 16), oldHash = hash.slice(0, 8);
                for (i = 0; i < 64; i++) {
                    var w15 = w[i - 15], w2 = w[i - 2], a = hash[0], e = hash[4];
                    var temp1 = hash[7] + ((e >>> 6 | e << 26) ^ (e >>> 11 | e << 21) ^ (e >>> 25 | e << 7)) + ((e & hash[5]) ^ ((~e) & hash[6])) + k[i] + (w[i] = (i < 16) ? w[i] : (w[i - 16] + ((w15 >>> 7 | w15 << 25) ^ (w15 >>> 18 | w15 << 14) ^ (w15 >>> 3)) + w[i - 7] + ((w2 >>> 17 | w2 << 15) ^ (w2 >>> 19 | w2 << 13) ^ (w2 >>> 10))) | 0);
                    var temp2 = ((a >>> 2 | a << 30) ^ (a >>> 13 | a << 19) ^ (a >>> 22 | a << 10)) + ((a & hash[1]) ^ (a & hash[2]) ^ (hash[1] & hash[2]));
                    hash = [(temp1 + temp2) | 0].concat(hash); hash[4] = (hash[4] + temp1) | 0;
                }
                for (i = 0; i < 8; i++) hash[i] = (hash[i] + oldHash[i]) | 0;
            }
            for (i = 0; i < 8; i++) {
                for (j = 3; j + 1; j--) {
                    var b = (hash[i] >> (j * 8)) & 255;
                    result += ((b < 16) ? 0 : '') + b.toString(16);
                }
            }
            return result;
        }

        function checkAuth() {
            var input = document.getElementById("passInput").value;
            var statusDiv = document.getElementById("loginStatus");
            if (generateHash(ADMIN_SALT + input) === ADMIN_HASH) {
                document.getElementById("login-panel").style.display = "none";
                document.getElementById("admin-panel").style.display = "block";
            } else {
                statusDiv.innerHTML = "Authentication Failed";
                statusDiv.className = "status error-text";
            }
        }

        function startServer() {
            shell.Run("py -m http.server 8000 --bind 127.0.0.1", 0, false);
            // Public Basic Auth removed to fix the login error loop from your screenshot
            shell.Run("ngrok http --url=unprimed-edmundo-citatory.ngrok-free.dev 8000", 0, false);
            
            var publicLink = "https://unprimed-edmundo-citatory.ngrok-free.dev/";
            var trackLink = "http://127.0.0.1:4040/inspect/http";

            initialLogsHtml = "<div class='log-entry'><span style='color:#d4c4a8'>[SYSTEM]</span> GHOST TUNNEL INITIALIZED</div>";
            initialLogsHtml += "<div class='log-entry'>[PUBLIC] <span style='color:#58a6ff'>" + publicLink + "</span></div>";
            initialLogsHtml += "<div class='log-entry'>[TRACK] <span style='color:#58a6ff'>" + trackLink + "</span></div>";
            initialLogsHtml += "<div style='color:#6b5a42; margin:10px 0;'>------------------------------------</div>";
            
            document.getElementById("logBox").innerHTML = initialLogsHtml;
            document.getElementById("statusBox").innerHTML = "Securely Online";
            document.getElementById("statusBox").className = "success-text";
            document.getElementById("statusDot").className = "status-dot online";
            
            window.setInterval(fetchLogs, 5000);
        }

        function stopServer() {
            shell.Run("taskkill /F /IM python.exe /T", 0, true);
            shell.Run("taskkill /F /IM ngrok.exe /T", 0, true);
            document.getElementById("statusBox").innerHTML = "System Offline";
            document.getElementById("statusBox").className = "error-text";
            document.getElementById("statusDot").className = "status-dot offline";
            document.getElementById("logBox").innerHTML = "<span style='color: #5a4a38; font-style: italic;'>Processes Terminated.</span>";
        }

        function fetchLogs() {
            var xhr = new XMLHttpRequest();
            xhr.open("GET", "http://127.0.0.1:4040/api/requests/http?limit=10", true);
            xhr.onload = function() {
                if (xhr.status == 200) {
                    var data = JSON.parse(xhr.responseText), html = "";
                    if(data.requests.length > 0) {
                        for(var i=0; i < data.requests.length; i++) {
                            var req = data.requests[i];
                            var time = new Date(req.start).toLocaleTimeString();
                            html += "<div class='log-entry'><span class='log-time'>[" + time + "]</span>GET " + req.request.uri + "</div>";
                        }
                        // Redraws logs with current data, keeping the top links intact
                        document.getElementById("logBox").innerHTML = initialLogsHtml + html;
                    }
                }
            };
            xhr.send();
        }
    </script>
</body>
</html>